# AAAS - Agent as a Service
# Copy this to .env and fill in your values

# Ollama settings (runs locally, no API key needed)
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# GitHub (optional - needed for GitHub integration)
# Get this at: github.com/settings/tokens → Generate new token (classic)
# Scopes needed: repo, workflow, project
GITHUB_TOKEN=

# GitHub repo to connect to (format: owner/repo-name)
GITHUB_REPO=

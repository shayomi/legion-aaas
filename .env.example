# AAAS - Agent as a Service
# Copy this to .env and fill in your values

# Ollama settings (runs locally, no API key needed)
AI_PROVIDER=ollama
OLLAMA_MODEL=mistral
OLLAMA_BASE_URL=http://localhost:11434

# Future hosted or alternative providers
CLAUDE_API_KEY=
OPENCODE_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=

# Optional: pin packs instead of using automatic recommendations
AAAS_PACKS=

# LEGION Swarm
LEGION_SWARM_BASE_URL=
LEGION_SWARM_ENV=local

# Hybrid SaaS sync placeholders
AAAS_SYNC_MODE=hybrid
AAAS_CLOUD_URL=
AAAS_PROJECT_ID=
AAAS_WORKSPACE_ID=

# GitHub (optional - needed for GitHub integration)
# Get this at: github.com/settings/tokens → Generate new token (classic)
# Scopes needed: repo, workflow, project
GITHUB_TOKEN=

# GitHub repo to connect to (format: owner/repo-name)
GITHUB_REPO=
